# Required
TELEGRAM_BOT_TOKEN=123456789:replace_me

# Optional (if empty, worker tries to auto-detect from getUpdates)
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE_URL=https://api.telegram.org
# Optional: separate endpoint for file uploads (sendVideo/sendDocument).
# If empty, TELEGRAM_API_BASE_URL is used.
TELEGRAM_UPLOAD_API_BASE_URL=
TELEGRAM_PARTICIPANT_PRESETS=@msavin_dev,@asdfasdf
TELEGRAM_UPLOAD_MAX_BYTES=51380224

# Optional: only for local telegram-bot-api container (profile local-bot-api)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Local docker-compose bind mount source
RECORDINGS_HOST_PATH=/root/.jitsi-meet-cfg/jibri/recordings

# Worker settings
RECORDINGS_DIR=/recordings
STATE_FILE=/app/data/state.json
TEMP_DIR=/tmp/call_clips
APP_TIMEZONE=Europe/Moscow
POLL_INTERVAL_SECONDS=30
FILE_MIN_AGE_SECONDS=60
STABILITY_WAIT_SECONDS=5
CLIP_DURATION_SECONDS=10
RUN_ONCE=false
UPDATES_TIMEOUT_SECONDS=2

# AI Tunnel transcription + summary
AITUNNEL_API_KEY=
AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1/
AITUNNEL_TRANSCRIBE_MODEL=whisper-1
AITUNNEL_SUMMARY_MODEL=gpt-4o-mini
AITUNNEL_TRANSCRIBE_LANGUAGE=ru

# Backward-compatible aliases if you still keep old OpenAI-style env names
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_TRANSCRIBE_MODEL=
OPENAI_SUMMARY_MODEL=
OPENAI_TRANSCRIBE_LANGUAGE=

# Chunking / transcript delivery tuning
OPENAI_AUDIO_CHUNK_SECONDS=900
OPENAI_SUMMARY_CHUNK_CHARS=30000
SEND_TRANSCRIPT_FILE=true

# Platform student directory via existing session/exchange API
PLATFORM_API_BASE_URL=http://host.docker.internal:8083
PLATFORM_IDENTITY_EXCHANGE_SECRET=dev-identity-exchange-secret
PLATFORM_IDENTITY_EXCHANGE_ISSUER=identity-service
PLATFORM_IDENTITY_EXCHANGE_AUDIENCE=platform
PLATFORM_API_ACTOR_SUBJECT_ID=1
PLATFORM_API_TELEGRAM_USERNAME=msavin_dev
PLATFORM_API_DISPLAY_NAME=Call Record Bot
PLATFORM_STUDENTS_CACHE_SECONDS=300

# Optional mentor_session matching from platform DB
PLATFORM_DB_HOST=
PLATFORM_DB_PORT=5434
PLATFORM_DB_NAME=
PLATFORM_DB_USER=
PLATFORM_DB_PASSWORD=
PLATFORM_SESSION_MATCH_WINDOW_MINUTES=180

# Reminder ping/backoff for unanswered steps
REMINDER_BASE_SECONDS=300
REMINDER_MAX_SECONDS=14400
REMINDER_TIMEZONE=Europe/Moscow
REMINDER_NIGHT_START_HOUR=23
REMINDER_NIGHT_END_HOUR=9
