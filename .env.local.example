# Copy to .env.local and fill with real secrets / host-specific values.

TELEGRAM_BOT_TOKEN=123456789:replace_me
TELEGRAM_CHAT_ID=

AITUNNEL_API_KEY=

# Usually same value as IDENTITY_EXCHANGE_SECRET in ../platform
PLATFORM_IDENTITY_EXCHANGE_SECRET=dev-identity-exchange-secret

# Use a technical username, not a real student nickname
PLATFORM_API_TELEGRAM_USERNAME=@call_record_bot

# Server-specific host path to Jibri recordings
RECORDINGS_HOST_PATH=/root/.jitsi-meet-cfg/jibri/recordings

# Optional upload endpoint for local telegram-bot-api
TELEGRAM_UPLOAD_API_BASE_URL=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional mentor_session matching from platform DB
PLATFORM_DB_HOST=
PLATFORM_DB_PORT=5434
PLATFORM_DB_NAME=
PLATFORM_DB_USER=
PLATFORM_DB_PASSWORD=
